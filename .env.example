DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
MODEL_PRO=deepseek-v4-pro
MODEL_FLASH=deepseek-v4-flash
WS_URL=ws://127.0.0.1:8080

# ========== 机器人基本配置 ==========
BOT_NAME=bot
ADMIN_USERNAME=admin
TRIGGER_PREFIX=@bot
# me / say / raw / json — me=动作, say=说话, raw=纯文本, json=JSON协议(服务端使用JSON时选此项)
SEND_MODE=me
COOLDOWN_SECONDS=15
REPLY_PREFIX=
COMMENT_PREFIX=[感知]

# ========== 调优参数 ==========
MAX_HISTORY=20
GLOBAL_CONTEXT_SIZE=10
MAX_COMMAND_BYTES=500
AUTO_COMMENT_INTERVAL=300
HEARTBEAT_CHECK_INTERVAL=30
HEARTBEAT_TIMEOUT=600
API_TIMEOUT=15
TEMPERATURE=0.7
MAX_TOKENS=300
RETRY_COUNT=2
RETRY_DELAY=1.5
RECONNECT_DELAY=5
RECONNECT_DELAY_LONG=10
